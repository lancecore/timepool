# Meeting Poll — front controller routing + hardening.
Options -Indexes

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
  # Don't rewrite real files or directories (assets, install.php, logo files, etc.)
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]
  # Everything else goes through the front controller.
  RewriteRule ^ index.php [L]
</IfModule>

# Never serve the database, config, or app source directly.
<FilesMatch "\.(sqlite|sqlite-wal|sqlite-shm)$">
  Require all denied
</FilesMatch>

<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
